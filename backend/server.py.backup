    ).to_list(100)
    return accounts

@api_router.post("/social/accounts", response_model=dict)
async def add_social_account(account: SocialAccount, current_user: dict = Depends(get_current_user)):
    """Add a social media account"""
    account_dict = {
        "id": str(uuid.uuid4()),
        "user_id": current_user["user_id"],
